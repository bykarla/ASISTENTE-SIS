# ==========================================
# 1. Base de Datos (PostgreSQL)
# ==========================================
# Adaptado para que coincida con tu docker-compose.yml actual
DB_USER=admin_uneti
DB_PASSWORD=superpassword2026
DB_HOST=localhost
DB_PORT=5433
DB_NAME=asistente_virtual

# ByKP: Variable creada para facilitar la conexión a la base de datos en un solo lugar
DATABASE_URL=postgresql://admin_uneti:superpassword2026@localhost:5433/asistente_virtual

# ==========================================
# 2. Caché y Memoria (Redis)
# ==========================================
REDIS_URL=redis://localhost:6379/0

# ==========================================
# 3. Inteligencia Artificial (Capa 2)
# ==========================================
# Ollama (Motor de LLM Local)
OLLAMA_URL=http://localhost:11434
LLM_MODEL=tinyllama  # o phi3:mini

# Whisper (Procesamiento de Voz)
WHISPER_MODEL=tiny   # tiny, base, small...

# ==========================================
# 4. Integración con el Core (Capa 3)
# ==========================================
# Core SIS (Nest.js de Ezequiel/Backend Principal)
SIS_CORE_URL=http://localhost:3000

# ==========================================
# 5. Seguridad y Autenticación
# ==========================================
# JWT (JSON Web Tokens para validar la identidad de los estudiantes)
SECRET_KEY=dev-secret-key
ALGORITHM=HS256